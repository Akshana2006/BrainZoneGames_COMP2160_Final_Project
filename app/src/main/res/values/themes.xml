<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="Theme.BrainZone" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">@color/purple_primary</item>
        <item name="colorPrimaryDark">@color/purple_dark</item>
        <item name="colorAccent">@color/pink_accent</item>
        <item name="android:windowBackground">@color/white</item>
    </style>

    <!-- Full-screen theme (used by all screens via manifest) -->
    <style name="Theme.BrainZone.NoActionBar" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/purple_primary</item>
        <item name="colorPrimaryDark">@color/purple_dark</item>
        <item name="colorAccent">@color/pink_accent</item>
        <item name="android:windowBackground">@color/white</item>
        <item name="android:statusBarColor">@color/purple_dark</item>
    </style>

    <!-- Button style used across the app -->
    <style name="BrainZoneButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:background">@drawable/btn_rounded</item>
        <item name="android:layout_marginBottom">12dp</item>
    </style>
</resources>
