<?xml version="1.0" encoding="utf-8"?>
<!-- Game2Activity – Memory Match with RecyclerView grid (Lecture 11) -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/gray_light">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/gradient_header"
        android:orientation="vertical"
        android:paddingTop="40dp"
        android:paddingBottom="16dp"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/game2_title"
            android:textSize="@dimen/text_xlarge"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <!-- Stats row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tvMoves"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/moves_label"
                android:textSize="@dimen/text_normal"
                android:textColor="@color/yellow_accent"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/time_elapsed"
                android:textSize="@dimen/text_normal"
                android:textColor="@color/cyan_accent"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvPairs"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/pairs_label"
                android:textSize="@dimen/text_normal"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:gravity="end" />
        </LinearLayout>
    </LinearLayout>

    <!-- Card grid (RecyclerView – Lecture 11) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCards"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="@dimen/card_margin"
        android:clipToPadding="false" />

    <!-- Back button -->
    <Button
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="@dimen/btn_height"
        android:text="@string/btn_back"
        android:textColor="@color/purple_primary"
        android:textSize="@dimen/text_medium"
        android:textStyle="bold"
        android:background="@drawable/btn_secondary"
        android:layout_margin="@dimen/screen_padding" />

</LinearLayout>
