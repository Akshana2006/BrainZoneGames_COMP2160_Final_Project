<?xml version="1.0" encoding="utf-8"?>
<!-- SettingsActivity – LinearLayout with nested sections (Lecture 6) -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/gray_light">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/gradient_header"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="40dp"
        android:paddingBottom="20dp"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/settings_title"
            android:textSize="@dimen/text_xlarge"
            android:textColor="@color/white"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/screen_padding">

            <!-- ── Audio section ──────────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔊 Audio"
                android:textSize="@dimen/text_medium"
                android:textColor="@color/purple_primary"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/section_card_bg"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <!-- Music toggle (ToggleButton – Lecture 7) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/label_music"
                        android:textSize="@dimen/text_medium"
                        android:textColor="@color/black" />

                    <ToggleButton
                        android:id="@+id/tbMusic"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textOn="ON"
                        android:textOff="OFF"
                        android:checked="true" />
                </LinearLayout>

                <!-- SFX toggle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/label_sfx"
                        android:textSize="@dimen/text_medium"
                        android:textColor="@color/black" />

                    <ToggleButton
                        android:id="@+id/tbSFX"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textOn="ON"
                        android:textOff="OFF"
                        android:checked="true" />
                </LinearLayout>
            </LinearLayout>

            <!-- ── Difficulty section ─────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎯 Difficulty"
                android:textSize="@dimen/text_medium"
                android:textColor="@color/purple_primary"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/section_card_bg"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <!-- RadioGroup for difficulty (RadioButton – Lecture 7) -->
                <RadioGroup
                    android:id="@+id/rgDifficulty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/rbEasy"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🟢 Easy  (small numbers, more time)"
                        android:textSize="@dimen/text_medium"
                        android:checked="true"
                        android:layout_marginBottom="8dp" />

                    <RadioButton
                        android:id="@+id/rbMedium"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🟡 Medium (larger range, balanced time)"
                        android:textSize="@dimen/text_medium"
                        android:layout_marginBottom="8dp" />

                    <RadioButton
                        android:id="@+id/rbHard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🔴 Hard  (max range, tight timer)"
                        android:textSize="@dimen/text_medium" />
                </RadioGroup>
            </LinearLayout>

            <!-- ── Data section ───────────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🗑️ Data"
                android:textSize="@dimen/text_medium"
                android:textColor="@color/purple_primary"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnResetScores"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height"
                android:text="@string/btn_reset_scores"
                android:textColor="@color/white"
                android:textSize="@dimen/text_medium"
                android:textStyle="bold"
                android:background="@drawable/btn_danger"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnBack"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height"
                android:text="@string/btn_back"
                android:textColor="@color/purple_primary"
                android:textSize="@dimen/text_medium"
                android:textStyle="bold"
                android:background="@drawable/btn_secondary" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
