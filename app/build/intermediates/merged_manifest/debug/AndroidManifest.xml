<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.brainzone"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="24"
        android:targetSdkVersion="34" />

    <!-- Permissions -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <permission
        android:name="com.example.brainzone.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.example.brainzone.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />

    <application
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:testOnly="true"
        android:theme="@style/Theme.BrainZone" >

        <!-- Splash (launcher entry point) -->
        <activity
            android:name="com.example.brainzone.SplashActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.BrainZone.NoActionBar" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Main Menu -->
        <activity
            android:name="com.example.brainzone.MainActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.BrainZone.NoActionBar" />

        <!-- Settings -->
        <activity
            android:name="com.example.brainzone.SettingsActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.BrainZone.NoActionBar" />

        <!-- Leaderboard -->
        <activity
            android:name="com.example.brainzone.LeaderboardActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.BrainZone.NoActionBar" />

        <!-- Game 1 – Multiplication Puzzle -->
        <activity
            android:name="com.example.brainzone.Game1Activity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.BrainZone.NoActionBar" />

        <!-- Game 2 – Memory Match -->
        <activity
            android:name="com.example.brainzone.Game2Activity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.BrainZone.NoActionBar" />

        <!-- Game 3 – Word Scramble -->
        <activity
            android:name="com.example.brainzone.Game3Activity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.BrainZone.NoActionBar" />

        <!-- Shared Game Result Screen -->
        <activity
            android:name="com.example.brainzone.GameResultActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.BrainZone.NoActionBar" />

        <!-- Background Music Service (Foreground) -->
        <service
            android:name="com.example.brainzone.BackgroundMusicService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="com.example.brainzone.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.profileinstaller.ProfileInstallerInitializer"
                android:value="androidx.startup" />
        </provider>

        <receiver
            android:name="androidx.profileinstaller.ProfileInstallReceiver"
            android:directBootAware="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.DUMP" >
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.INSTALL_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SKIP_FILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SAVE_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.BENCHMARK_OPERATION" />
            </intent-filter>
        </receiver>
    </application>

</manifest>